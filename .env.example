# Azure DevOps PR Skill - Environment Variables
# Copy this file to .env and fill in your values
# Then source it: source .env

# ==============================================================================
# REQUIRED VARIABLES
# ==============================================================================

# Your Azure DevOps organization name
# Found in URL: https://dev.azure.com/YOUR-ORG/...
AZURE_DEVOPS_ORG="your-organization"

# Your Azure DevOps project name
# Found in URL: https://dev.azure.com/your-org/YOUR-PROJECT/...
# Note: Case-sensitive!
AZURE_DEVOPS_PROJECT="your-project"

# Personal Access Token (PAT)
# Create at: https://dev.azure.com/{org}/_usersSettings/tokens
# Required scopes:
#   - vso.work (Work Items - Read)
#   - vso.work_write (Work Items - Read & Write)
#   - vso.code_write (Code - Read & Write)
AZURE_DEVOPS_PAT="your-personal-access-token"

# ==============================================================================
# OPTIONAL VARIABLES
# ==============================================================================

# Default reviewers (comma-separated GUIDs)
# AZURE_DEVOPS_REVIEWERS=""

# Override target branch for PRs (default: auto-detect main/master)
# AZURE_DEVOPS_TARGET_BRANCH="develop"

# Enable debug logging (set to "true" to enable)
# AZURE_DEVOPS_DEBUG="false"
